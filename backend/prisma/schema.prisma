generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Colaborador {
  id            Int      @id @default(autoincrement())
  nome          String
  cpf           String   @unique
  cargo         String?
  filial        String?
  setor         String?
  dataAdmissao  String?
  status        String?
  risco         String?
  createdAt     DateTime @default(now())
}

model Ferias {
  id                 Int      @id @default(autoincrement())
  nome               String
  filial             String?
  periodoAquisitivo  String?
  diasDevidos        Int?
  vencimento         String?
  emDobro            String?
  passivo            String?
  status             String?
  createdAt          DateTime @default(now())
}

model Exame {
  id            Int      @id @default(autoincrement())
  nome          String
  filial        String?
  tipoExame     String?
  ultimoExame   String?
  vencimento    String?
  diasAtraso    Int?
  passivo       String?
  status        String?
  createdAt     DateTime @default(now())
}

model ESocial {
  id            Int      @id @default(autoincrement())
  evento        String
  descricao     String?
  pendencias    Int?
  passivo       String?
  criticidade   String?
  createdAt     DateTime @default(now())
}

model ImportHistory {
  id        Int      @id @default(autoincrement())
  tipo      String
  arquivo   String
  registros Int
  createdAt DateTime @default(now())
}
